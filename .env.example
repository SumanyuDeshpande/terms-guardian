# ─────────────────────────────────────────────────────────────
#  Terms Guardian — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  NEVER commit your real .env file to GitHub.
# ─────────────────────────────────────────────────────────────

# Your AI API key 
API_KEY=your_api_key_here

# The full API endpoint URL for your chosen model
# Examples:
#   Gemini 2.0 Flash → https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
#   Gemini 1.5 Pro   → https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent
MODEL_URL=your_model_api_url_here
